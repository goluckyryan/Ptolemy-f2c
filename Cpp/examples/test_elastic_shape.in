HEADER  SHAPE linkule regression test (16O+48Ca @ 56 MeV)
$ Tests the SHAPE potential-form linkule (LINKUL LOC=8 via MAKPOT L800).
$ Without the MYINTS-persistence fix (source_potentials.cpp:488), the second
$ calculation segfaults. Without the ALLOCATE fix (contrl_translated.cpp:671),
$ the realshape array is rejected with "EXCEEDED ALLOCATOR ... ROOM FOR ONLY N".
$ The harness compares first-pass TOTAL (plain WS); successful completion of
$ the second pass (SHAPE-tabulated WS) is implicit verification.
ANGLESTEP = 5
$
CHANNEL  16O + 48CA
ELAB = 56
$
V = 36.9  A = .4175  R0 = 1.35  RC0 = 1.2
W = 78  RI0 = 1.27  AI = .28
ELASTIC SCATTERING
;
$
$  Now repeat with SHAPE-tabulated form of the same WS potential
$
asymptopia 30
REALPOTENTIAL SHAPE
ALLOCATE realSCALE =  0 20
v = 1
allocate realshape
