HEADER  TEST02
$+ PRINT = 999999
ANGLESTEP = 5
$
CHANNEL  16O + 48CA
ELAB = 56
$
V = 36.9  A = .4175  R0 = 1.35  RC0 = 1.2
VI = 78  RI0 = 1.27  AI = .28
$+ STEPSIZE = .1  WRITESTEP = .1  CHECKASYMPT
$
$  FIRST NO WKB CHOICE OF LMIN, LMAX
$
LMIN = 29  LMAX = 30
$+ KEYWORDS
;
NSCATALOG
$+ DUMPALL
$
$  NOW THE AUTOMATIC CHOICE OF LMIN
$
UNDEFINE WRITESTEP
NOCHECKASYMP
UNDEFINE LMIN    UNDEFINE LMAX
ELASTIC SCATTERING
;
NSCATALOG
$+ DUMPALL
$
$  NOW USE THE FOLDED COULOMB POTENTIAL
$
UNDEFINE RC0
;
$
$  JUST REAL SCATTERING
$
REALWAVE
W=0  UNDEFINE RI0  UNDEFINE AI
NOELASTIC  LMIN=29  LMAX=29
$+ WRITESTEP = .1
;
ELASTIC  UNDEFINE LMIN  UNDEFINE LMAX  WRITESTEP=0
;
$+ DUMPALL
$
$  PURE COULOMB SCATTERING
$
V = 0    W = 0   ;
$+ DUMPALL
$
$  PURE NUCLEAR SCATTERING
$
COMPLEXWAVE
ZP = 0   V = 36.9   VI = 78  RI0=1.27  AI = .28   ;
$
$  SPIN-ORBIT FORCES
$
CHANNEL  P + 48CA
LMAXADD = 10
$  FIRST NO S.O.
UNDEFINE RC0  ;
$  NOW REAL  S.O.
VSO = 7;
$   NOW COMPLEX S.O.
VSOI  = 12  ;
$+ DUMPALL
$
$  IDENTICAL PARTICLES
$
VSO = 0   VSOI = 0
ANGLEMAX = 180
$
$  NON IDENTICAL FIRST
$
CHANNEL  12C + 12C(.0001)  ;
LMAXADD = 12
$+ DUMPALL
$
$  IDENTICAL BOSONS OF SPIN 0
$
CHANNEL  12C + 12C  ;
$
$  IDENTICAL  SPIN-1 BOSONS
$
 CHANNEL  12C(1+  1.2)  +  12C(1+  1.2)
;
$
$  IDENTICAL  FERMIONS
$
CHANNEL  12C(1/2 1.2)  +  12C(1/2  1.2)
;
$
$  SPIN-ORBIT FOR SPIN 1
$
CHANNEL:  D + 46TI   ELAB = 13   ELASTIC SCATTERING
V = 94.1   R0 = 1.11   A = 0.97   RC0 = 1.3
VI = 0   VSI = 14.3   RSI0 = 1.38   ASI = 0.72
VSO = 6.7   RSO0 = 0.88   ASO = 0.73
VSOI = 1.7   RSOI0 = 0.72   ASOI = 0.20
LMAXADD = 8   STEPSIZE = 0.1   ASYMPTOPIA = 13   NBACK = 1
;
$
$  TR TENSOR POTENTIALS
$
VTR = 0.4   RTR0 = 1.70   ATR = 0.55
VTRI = 0.4   RTRI0 = 1.58   ATRI = 0.21
;
$
$  TL TENSOR POTENTIALS
$
VTR = 0   VTRI = 0   VTL = 1  ;
$
$  TPR (APPROXIMATE TP - P**2*TR) TENSOR POTENTIALS
$
VTL = 0   VTPR = 5   ;
NSCATALOG
RETURN
